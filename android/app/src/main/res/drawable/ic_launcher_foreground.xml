<?xml version="1.0" encoding="utf-8"?>
<!--
  108dp x 108dp foreground. Visible content lives within the central 72dp circle (insets 18dp on every side).
  Composition: thin ink-grid (4x4) with two opposing stones — universal Go motif.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Grid lines, drawn as thin filled rects so they render crisply at small sizes. -->
    <!-- 4x4 grid covering 54dp square centered at (54,54): from x=27 to x=81. -->
    <group android:translateX="0" android:translateY="0">

        <!-- Vertical lines (4 lines, evenly spaced at 18dp). -->
        <path android:fillColor="#221A10" android:fillAlpha="0.55"
            android:pathData="M26.6,27 h0.8 v54 h-0.8 z"/>
        <path android:fillColor="#221A10" android:fillAlpha="0.55"
            android:pathData="M44.6,27 h0.8 v54 h-0.8 z"/>
        <path android:fillColor="#221A10" android:fillAlpha="0.55"
            android:pathData="M62.6,27 h0.8 v54 h-0.8 z"/>
        <path android:fillColor="#221A10" android:fillAlpha="0.55"
            android:pathData="M80.6,27 h0.8 v54 h-0.8 z"/>

        <!-- Horizontal lines. -->
        <path android:fillColor="#221A10" android:fillAlpha="0.55"
            android:pathData="M27,26.6 h54 v0.8 h-54 z"/>
        <path android:fillColor="#221A10" android:fillAlpha="0.55"
            android:pathData="M27,44.6 h54 v0.8 h-54 z"/>
        <path android:fillColor="#221A10" android:fillAlpha="0.55"
            android:pathData="M27,62.6 h54 v0.8 h-54 z"/>
        <path android:fillColor="#221A10" android:fillAlpha="0.55"
            android:pathData="M27,80.6 h54 v0.8 h-54 z"/>

        <!-- Hoshi (center star point). -->
        <path android:fillColor="#221A10"
            android:pathData="M53,53 h2 v2 h-2 z"/>

        <!-- Stone shadows. -->
        <path android:fillColor="#000000" android:fillAlpha="0.22"
            android:pathData="M45,46 m-13,0 a13,13 0 1,0 26,0 a13,13 0 1,0 -26,0 z"/>
        <path android:fillColor="#000000" android:fillAlpha="0.22"
            android:pathData="M63,64 m-13,0 a13,13 0 1,0 26,0 a13,13 0 1,0 -26,0 z"/>

        <!-- Black stone at upper-left (centered on grid intersection 44.6,44.6). -->
        <path android:pathData="M44.6,44.6 m-12,0 a12,12 0 1,0 24,0 a12,12 0 1,0 -24,0 z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:type="radial"
                    android:centerX="40" android:centerY="40"
                    android:gradientRadius="18">
                    <item android:offset="0.0" android:color="#3B3B3B"/>
                    <item android:offset="1.0" android:color="#0A0A0A"/>
                </gradient>
            </aapt:attr>
        </path>

        <!-- White stone at lower-right (centered on intersection 62.6,62.6). -->
        <path android:pathData="M62.6,62.6 m-12,0 a12,12 0 1,0 24,0 a12,12 0 1,0 -24,0 z"
            android:strokeColor="#221A10" android:strokeAlpha="0.55" android:strokeWidth="0.6">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:type="radial"
                    android:centerX="58" android:centerY="58"
                    android:gradientRadius="18">
                    <item android:offset="0.0" android:color="#FFFCF6"/>
                    <item android:offset="1.0" android:color="#E1D5BF"/>
                </gradient>
            </aapt:attr>
        </path>
    </group>
</vector>
